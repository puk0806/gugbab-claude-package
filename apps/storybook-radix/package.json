{
  "name": "@gugbab/storybook-radix",
  "version": "0.0.0",
  "private": true,
  "description": "Storybook showcase for @gugbab/styled-radix (Radix Themes lookalike, grx-* classes)",
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6007 --no-open",
    "build": "storybook build --output-dir storybook-static",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf storybook-static .turbo node_modules/.cache"
  },
  "dependencies": {
    "@gugbab/headless": "workspace:*",
    "@gugbab/styled-radix": "workspace:*",
    "@gugbab/tokens": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@gugbab/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "storybook": "^10.3.5",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
