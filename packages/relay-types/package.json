{
  "name": "@gugbab/relay-types",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript types for gugbab-claude-relay API",
  "license": "MIT",
  "author": "gugbab",
  "homepage": "https://github.com/puk0806/gugbab-claude-package/tree/main/packages/relay-types#readme",
  "bugs": {
    "url": "https://github.com/puk0806/gugbab-claude-package/issues"
  },
  "keywords": [
    "typescript",
    "openapi",
    "relay",
    "types",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puk0806/gugbab-claude-package.git",
    "directory": "packages/relay-types"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "devDependencies": {
    "@gugbab/tsconfig": "workspace:*",
    "@gugbab/types-generator": "workspace:*",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.3.6",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
