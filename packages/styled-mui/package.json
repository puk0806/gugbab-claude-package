{
  "name": "@gugbab-ui/styled-mui",
  "version": "0.0.1",
  "description": "MUI lookalike styled wrappers over @gugbab-ui/headless headless components",
  "license": "MIT",
  "author": "gugbab",
  "homepage": "https://github.com/puk0806/gugbab-claude-package/tree/main/packages/styled-mui#readme",
  "bugs": {
    "url": "https://github.com/puk0806/gugbab-claude-package/issues"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "material",
    "mui",
    "design-system",
    "headless"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puk0806/gugbab-claude-package.git",
    "directory": "packages/styled-mui"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@gugbab-ui/headless": "workspace:*",
    "@gugbab-ui/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@gugbab-ui/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
