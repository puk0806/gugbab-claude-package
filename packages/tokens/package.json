{
  "name": "@gugbab/tokens",
  "version": "1.0.0",
  "description": "Design tokens for @gugbab/* — static token snapshots (MUI / Radix lookalike) → CSS variables. No external library dependencies.",
  "license": "MIT",
  "author": "gugbab",
  "homepage": "https://github.com/puk0806/gugbab-claude-package/tree/main/packages/tokens#readme",
  "bugs": {
    "url": "https://github.com/puk0806/gugbab-claude-package/issues"
  },
  "keywords": [
    "design-tokens",
    "css-variables",
    "design-system",
    "theme",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puk0806/gugbab-claude-package.git",
    "directory": "packages/tokens"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./mui.css": "./dist/mui.css",
    "./radix.css": "./dist/radix.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "devDependencies": {
    "@gugbab/tsconfig": "workspace:*",
    "tsup": "^8.3.6",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
