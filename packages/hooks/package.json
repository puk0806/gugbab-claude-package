{
  "name": "@gugbab/hooks",
  "version": "1.0.1",
  "description": "Framework-agnostic React hooks for @gugbab/* (headless 빌딩블록)",
  "license": "MIT",
  "author": "gugbab",
  "homepage": "https://github.com/puk0806/gugbab-claude-package/tree/main/packages/hooks#readme",
  "bugs": {
    "url": "https://github.com/puk0806/gugbab-claude-package/issues"
  },
  "keywords": [
    "react",
    "react-hooks",
    "hooks",
    "headless",
    "framework-agnostic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puk0806/gugbab-claude-package.git",
    "directory": "packages/hooks"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup && node ../../scripts/inject-use-client.mjs dist/index.mjs dist/index.cjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@gugbab/utils": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@gugbab/tsconfig": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
